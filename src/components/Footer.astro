---
const today = new Date();
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
const earliest = essays.reduce((min, p) => 
  p.data.pubDate < min ? p.data.pubDate : min, 
  essays[0].data.pubDate
);
const startYear = earliest.getFullYear();
const currentYear = new Date().getFullYear();
const yearDisplay = startYear === currentYear ? `${startYear}` : `${startYear} – ${currentYear}`;
---


<footer>
  <div class="footer-inner">
    <p>© {yearDisplay} 记录</p>
    <div class="footer-links">
      <!--<a href="mailto:your@email.com">邮件</a>-->
      <a href="https://github.com/huangyu9887" target="_blank">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 64px;
    padding: 28px 5vw 48px;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    max-width: 660px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }
  footer p { font-size: 12px; color: var(--faint); font-weight: 300; }
  .footer-links { display: flex; gap: 16px; }
  .footer-links a {
    font-size: 12px;
    color: var(--faint);
    text-decoration: none;
    transition: color 0.15s;
    border-bottom: none;
  }
  .footer-links a:hover { color: var(--muted); border-bottom: none; }
</style>