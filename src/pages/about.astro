---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-CN">
  <head><BaseHead title="关于" description="关于这里和关于我。" /></head>
  <body>
    <Header />
    <main>
      <div class="page">
        <div class="block">
          <h2>关于这里</h2>
          <p>探索生活与科技。写生活、读书、或是记录某个情绪。</p>
          <p>是我的第二大脑，也希望对你有帮助。</p>
        </div>
        <div class="block">
          <h2>关于我</h2>
  <p>一枚IT行业从业者。</p>
          <p>喜欢读书、走路、骑车、坐地铁、发呆。</p>
          <p>相信「慢慢来比较快」。</p>
        </div>
        <div class="block">
          <h2>联系</h2>
          <ul class="contact-list">
            <!--<li><span class="label">邮件</span><a href="mailto:your@email.com">lanchengji_9887@sina.com</a></li>-->
            <li><span class="label">GitHub</span><a href="https://github.com/huangyu9887" target="_blank">github.com/huangyu9887</a></li>
            <li><span class="label">公众号</span><span class="val">花菜手记</span></li>
          </ul>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main { padding: 44px 5vw 0; }
  .page { max-width: 660px; margin: 0 auto; }
  .block { margin-bottom: 40px; }
  h2 {
    font-family: var(--serif);
    font-size: 16px; font-weight: 400;
    letter-spacing: 0.04em; margin-bottom: 14px;
  }
  p {
    font-family: var(--serif);
    font-size: 16px; font-weight: 300;
    line-height: 1.95; margin-bottom: 0.9em;
    color: var(--text);
  }
  .contact-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .contact-list li { display: flex; align-items: baseline; gap: 14px; font-size: 14px; font-weight: 300; }
  .label { font-size: 12px; color: var(--faint); width: 40px; flex-shrink: 0; }
  .contact-list a { color: var(--link); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.15s; }
  .contact-list a:hover { border-bottom-color: var(--link); }
  .val { color: var(--muted); }
</style>
