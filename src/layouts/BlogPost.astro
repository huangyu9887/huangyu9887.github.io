---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400&family=Noto+Sans+SC:wght@300;400&display=swap" rel="stylesheet">
  </head>
  <body>
    <Header />
    <main>
      <div class="page">
        <a class="back-btn" href="javascript:history.back()">← 返回</a>
        <article>
          <div class="post-header">
            <h1>{title}</h1>
            <p class="post-meta">
              <FormattedDate date={pubDate} />
              {updatedDate && <span>· 更新于 <FormattedDate date={updatedDate} /></span>}
            </p>
          </div>
          <div class="post-body">
            <slot />
          </div>
          <p class="post-end">· · ·</p>
        </article>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main { padding: 40px 5vw 0; }
  .page { max-width: 660px; margin: 0 auto; }

  .back-btn {
    display: inline-block;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 36px;
    transition: color 0.15s;
    border-bottom: none;
  }
  .back-btn:hover { color: var(--text); border-bottom: none; }

  .post-header { margin-bottom: 32px; }
  h1 {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: 0.04em;
    margin-bottom: 10px;
  }
  .post-meta { font-size: 12px; color: var(--faint); font-weight: 300; }

  .post-body {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 300;
    line-height: 1.85;
    color: var(--text);
  }
  .post-body :global(p) { margin-bottom: 1.5em; text-indent: 0; }
  .post-body :global(p:first-child) { text-indent: 0; }
  .post-body :global(h3) {
    font-size: 16px; font-weight: 400;
    margin: 2em 0 0.8em; letter-spacing: 0.03em;
  }
  .post-body :global(blockquote) {
    border-left: 2px solid var(--faint);
    padding: 0 0 0 20px;
    margin: 2em 0;
    color: var(--muted);
  }
  .post-body :global(ul) { padding-left: 1.5em; margin-bottom: 1.5em; }
  .post-body :global(li) { font-size: 16px; font-weight: 300; margin-bottom: 0.4em; }

  .post-end {
    text-align: center;
    color: var(--faint);
    letter-spacing: 10px;
    margin: 48px 0 0;
    font-size: 14px;
  }
</style>